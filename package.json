{
  "name": "@machso/apexproxy",
  "bin": "./scripts/copy.js",
  "files": [
    "force-app/main/default/classes",
    "scripts/copy.js"
  ],
  "version": "1.0.0",
  "description": "Proxy pattern for Salesforce Apex",
  "license": "MIT",
  "scripts": {
    "sf:org:no-ns": "export NS_FLAG='--no-namespace'; npm run sf:org",
    "sf:org": "sf org create scratch -y 7 -a proxy0 -d -w 15 -f config/scratch-pkg-validation.json $NS_FLAG",
    "sf:regression": "sf project deploy start -w 15 -d force-app; npm run sf:test",
    "sf:test": "sf apex test run -w 15 -c -t ProxyTest",
    "version:cover": "export CODE_FLAG='--code-coverage'; npm run version:create",
    "version:create": "sf package version create -d force-app $CODE_FLAG -f config/scratch-pkg-validation.json -x -w 15"
  },
  "devDependencies": {
    "@cparra/apexdocs": "^3.3.2",
    "@lwc/eslint-plugin-lwc": "^1.1.2",
    "@prettier/plugin-xml": "^3.2.2",
    "@salesforce/eslint-config-lwc": "^3.2.3",
    "@salesforce/eslint-plugin-aura": "^2.0.0",
    "@salesforce/eslint-plugin-lightning": "^1.0.0",
    "@salesforce/sfdx-lwc-jest": "^3.1.0",
    "eslint": "^8.11.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jest": "^27.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-apex": "^2.0.1"
  },
  "lint-staged": {
    "**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}": [
      "prettier --write"
    ],
    "**/{aura,lwc}/**/*.js": [
      "eslint"
    ]
  }
}